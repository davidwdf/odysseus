{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/precommit-docs-check.mjs\"",
            "timeout": 15,
            "statusMessage": "Checking if docs need updating before commit…"
          }
        ]
      }
    ]
  }
}
